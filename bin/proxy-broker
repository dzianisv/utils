#!/bin/bash
#
# proxy-broker — a local, geo-located proxy backed by Tor.
#
# Exposes a stable proxy on localhost whose exit IP is in a country YOU choose,
# so you can reach services that aren't available from your real location. Tor
# is used as the engine because it is free, self-hosted, and — unlike scraped
# "free public proxies" — actually reliable for HTTPS and lets you pin the exit
# country.
#
# Two local endpoints are provided:
#   socks5://127.0.0.1:9050   <- use this in your browser (handles HTTP+HTTPS)
#   http://127.0.0.1:3000     <- HTTP-proxy interface (HTTPS/CONNECT only)
#
# Usage:
#   proxy-broker [serve]      Run Tor in the foreground (default).
#   proxy-broker install      Copy self to ~/.local/bin and install a launchd
#                             service that starts at login and restarts on crash.
#   proxy-broker uninstall    Remove the launchd service (keeps the binary).
#   proxy-broker status       Show service state, ports, and the live exit IP.
#   proxy-broker country WHERE  Set the exit location and restart. WHERE is:
#                               non-us       any exit except the United States
#                               de           one country (2-letter code)
#                               de,fr,nl     a set of countries
#
set -euo pipefail

# --- config ---------------------------------------------------------------
SOCKS_PORT="9050"
HTTP_PORT="3000"
# Exit selection. Either:
#   non-us         -> any exit in the world EXCEPT the United States (big pool)
#   de             -> pin to one country (2-letter code)
#   de,fr,nl       -> restrict to a set of countries
DEFAULT_COUNTRY="non-us"
LABEL="com.dzianisvv.proxy-broker"

BIN_DIR="$HOME/.local/bin"
BIN_PATH="$BIN_DIR/proxy-broker"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
CONFIG_DIR="$HOME/.config/proxy-broker"
COUNTRY_FILE="$CONFIG_DIR/exit-country"
TORRC="$CONFIG_DIR/torrc"
DATA_DIR="$HOME/.local/share/proxy-broker/tor"   # persistent => fast restarts
LOG_DIR="$HOME/Library/Logs"
LOG_FILE="$LOG_DIR/proxy-broker.log"

# launchd hands us a minimal PATH; make Homebrew's tor reachable.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin"

# --- helpers --------------------------------------------------------------

# Absolute path to this script, regardless of how it was invoked.
self_path() {
  local src="${BASH_SOURCE[0]}"
  cd "$(dirname "$src")" >/dev/null 2>&1 && printf '%s/%s\n' "$(pwd)" "$(basename "$src")"
}

# The chosen exit country (sidecar file wins over the built-in default).
exit_country() {
  if [ -f "$COUNTRY_FILE" ]; then
    tr -d '[:space:]' < "$COUNTRY_FILE" | tr 'A-Z' 'a-z'
  else
    echo "$DEFAULT_COUNTRY"
  fi
}

ensure_tor() {
  if command -v tor >/dev/null 2>&1; then return 0; fi
  if command -v brew >/dev/null 2>&1; then
    echo "proxy-broker: installing tor via Homebrew ..." >&2
    brew install tor
  else
    echo "proxy-broker: tor not found and Homebrew unavailable. Install tor first." >&2
    exit 1
  fi
}

# Translate the exit selection into a Tor directive line.
#   non-us / any  -> ExcludeExitNodes {us}   (anywhere but the US)
#   "de"          -> ExitNodes {de}
#   "de,fr,nl"    -> ExitNodes {de},{fr},{nl}
tor_exit_directive() {
  local sel; sel="$(exit_country)"
  case "$sel" in
    non-us|nonus|any|world)
      echo "ExcludeExitNodes {us}"
      ;;
    *)
      local list="" code
      for code in ${sel//,/ }; do list="${list:+$list,}{$code}"; done
      echo "ExitNodes $list"
      ;;
  esac
}

# Generate torrc from the current config + chosen exit selection.
write_torrc() {
  mkdir -p "$CONFIG_DIR" "$DATA_DIR" "$LOG_DIR"
  chmod 700 "$DATA_DIR"
  cat > "$TORRC" <<TORRC_EOF
SocksPort 127.0.0.1:${SOCKS_PORT}
HTTPTunnelPort 127.0.0.1:${HTTP_PORT}
DataDirectory ${DATA_DIR}
# Exit selection. StrictNodes 1 = fail closed: Tor obeys the restriction
# strictly rather than ever falling back to a disallowed (e.g. US) exit.
$(tor_exit_directive)
StrictNodes 1
Log notice stdout
TORRC_EOF
}

# --- commands -------------------------------------------------------------

do_serve() {
  ensure_tor
  write_torrc
  echo "proxy-broker: exit country = $(exit_country); socks5://127.0.0.1:${SOCKS_PORT}, http://127.0.0.1:${HTTP_PORT}" >&2
  exec tor -f "$TORRC"
}

do_install() {
  ensure_tor

  # 1. Install the binary to ~/.local/bin.
  mkdir -p "$BIN_DIR" "$LOG_DIR"
  local src; src="$(self_path)"
  if [ "$src" != "$BIN_PATH" ]; then
    cp "$src" "$BIN_PATH"
  fi
  chmod +x "$BIN_PATH"
  echo "proxy-broker: installed -> $BIN_PATH"

  # 2. Write the launchd service.
  mkdir -p "$(dirname "$PLIST")"
  cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${BIN_PATH}</string>
        <string>serve</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${HOME}/.local/bin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
</dict>
</plist>
PLIST_EOF
  echo "proxy-broker: wrote service -> $PLIST"

  # 3. (Re)load it.
  launchctl unload "$PLIST" 2>/dev/null || true
  launchctl load -w "$PLIST"
  echo "proxy-broker: service loaded (exit: $(exit_country))."
  echo "proxy-broker: point your browser at socks5://127.0.0.1:${SOCKS_PORT}"
  echo "proxy-broker: logs -> $LOG_FILE"
}

do_uninstall() {
  launchctl unload "$PLIST" 2>/dev/null || true
  rm -f "$PLIST"
  echo "proxy-broker: service removed ($PLIST). Binary at $BIN_PATH left in place."
}

# Restart the launchd service if it's loaded (used after a config change).
restart_service() {
  if launchctl list 2>/dev/null | grep -q "$LABEL"; then
    launchctl kickstart -k "gui/$(id -u)/$LABEL" 2>/dev/null \
      || { launchctl unload "$PLIST" 2>/dev/null; launchctl load -w "$PLIST"; }
    return 0
  fi
  return 1
}

do_country() {
  local cc="${1:-}"
  cc="$(printf '%s' "$cc" | tr 'A-Z' 'a-z' | tr -d '[:space:]')"
  # Accept: non-us / any, a single 2-letter code, or a comma-separated list.
  if ! printf '%s' "$cc" | grep -qiE '^(non-us|nonus|any|world|[a-z]{2}(,[a-z]{2})*)$'; then
    echo "proxy-broker: expected 'non-us', a 2-letter code (de, gb, nl, jp), or a list (de,fr,nl). Got: '$cc'" >&2
    exit 1
  fi
  mkdir -p "$CONFIG_DIR"
  echo "$cc" > "$COUNTRY_FILE"
  write_torrc
  echo "proxy-broker: exit country set to '$cc'."
  if restart_service; then
    echo "proxy-broker: service restarted; new circuits will exit via '$cc' (give it ~15s)."
  else
    echo "proxy-broker: service not loaded — run 'proxy-broker install' or 'serve'."
  fi
}

do_status() {
  echo "Service ($LABEL):"
  if launchctl list 2>/dev/null | grep -q "$LABEL"; then
    launchctl list | awk 'NR==1 || /'"$LABEL"'/'
  else
    echo "  not loaded"
  fi
  echo
  echo "Configured exit country: $(exit_country)"
  echo
  for p in "$SOCKS_PORT" "$HTTP_PORT"; do
    if lsof -nP -iTCP:"$p" -sTCP:LISTEN 2>/dev/null | grep -q LISTEN; then
      echo "Listening on 127.0.0.1:$p  (up)"
    else
      echo "Listening on 127.0.0.1:$p  (down)"
    fi
  done
  echo
  echo "Live exit IP (via socks5://127.0.0.1:$SOCKS_PORT):"
  local info
  info="$(curl -s --max-time 20 --socks5-hostname "127.0.0.1:$SOCKS_PORT" https://ipinfo.io/json 2>/dev/null)" || true
  if [ -n "$info" ]; then
    printf '%s\n' "$info" | grep -iE '"ip"|"city"|"country"|"org"' | sed 's/^/  /'
  else
    echo "  (no response yet — Tor may still be bootstrapping)"
  fi
  if [ -f "$LOG_FILE" ]; then
    echo
    echo "Recent log ($LOG_FILE):"
    tail -n 6 "$LOG_FILE"
  fi
}

# --- dispatch -------------------------------------------------------------
case "${1:-serve}" in
  serve|"")   do_serve ;;
  install)    do_install ;;
  uninstall)  do_uninstall ;;
  status)     do_status ;;
  country)    shift; do_country "${1:-}" ;;
  -h|--help|help)
    sed -n '2,/^set -euo/p' "$(self_path)" | sed 's/^# \{0,1\}//; /^set -euo/d'
    ;;
  *)
    echo "proxy-broker: unknown command '$1' (try: serve, install, uninstall, status, country)" >&2
    exit 1
    ;;
esac
